generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum PlanTier {
  FREE
  PRO
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum BillingStatus {
  NONE
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  planTier        PlanTier         @default(FREE)
  accounts        Account[]
  sessions        Session[]
  resumes         Resume[]
  coverLetters    CoverLetter[]
  jobApplications JobApplication[]
  usage           UserUsage?
  billingSubscription BillingSubscription?
}

model Resume {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String   @default("")
  personal    Json
  experience  Json
  education   Json
  skills      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CoverLetter {
  id          String   @id @default(cuid())
  role        String
  company     String
  tone        String
  content     String   @db.Text
  jobDetails  String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model JobApplication {
  id          String            @id @default(cuid())
  company     String
  role        String
  status      ApplicationStatus @default(WISHLIST)
  appliedDate DateTime?
  link        String?
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
}

model UserUsage {
  id                   String   @id @default(cuid())
  resumesCreated       Int      @default(0)
  coverLettersCreated  Int      @default(0)
  coverLetterGenerations Int    @default(0)
  bulletImprovements   Int      @default(0)
  billingPeriodStart   DateTime @default(now())
  lastActiveAt         DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingSubscription {
  id                String          @id @default(cuid())
  provider          String          @default("XENDIT")
  status            BillingStatus   @default(NONE)
  billingInterval   BillingInterval?
  amount            Int?
  currency          String          @default("PHP")
  xenditExternalId  String?         @unique
  xenditInvoiceId   String?         @unique
  xenditInvoiceUrl  String?
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  lastPaidAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
